void DashLabel(string name, int x, int y, string text, color clr, int fontSize, bool bold)
{
   if(ObjectFind(0, name) < 0)
      ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
   ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
   ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
   ObjectSetString (0, name, OBJPROP_TEXT,      text);
   ObjectSetInteger(0, name, OBJPROP_COLOR,     clr);
   ObjectSetInteger(0, name, OBJPROP_FONTSIZE,  fontSize);
   ObjectSetString (0, name, OBJPROP_FONT,      bold ? "Arial Bold" : "Courier New");
   ObjectSetInteger(0, name, OBJPROP_CORNER,    CORNER_LEFT_UPPER);
}

//+------------------------------------------------------------------+
//|  OnTradeTransaction — detect TP/SL hits for alerts               |
//+------------------------------------------------------------------+
void OnTradeTransaction(const MqlTradeTransaction &trans,
                        const MqlTradeRequest     &request,
                        const MqlTradeResult      &result)
{
   if(trans.type != TRADE_TRANSACTION_DEAL_ADD) return;
   if(!HistoryDealSelect(trans.deal)) return;

   ulong  dealMagic = HistoryDealGetInteger(trans.deal, DEAL_MAGIC);
   if(dealMagic != (ulong)Magic) return;

   ulong  posTicket = HistoryDealGetInteger(trans.deal, DEAL_POSITION_ID);
   ENUM_DEAL_REASON reason = (ENUM_DEAL_REASON)HistoryDealGetInteger(trans.deal, DEAL_REASON);
   ENUM_DEAL_TYPE   dtype  = (ENUM_DEAL_TYPE)HistoryDealGetInteger(trans.deal, DEAL_TYPE);
   double profit = HistoryDealGetDouble(trans.deal, DEAL_PROFIT);
   string symbol = HistoryDealGetString(trans.deal, DEAL_SYMBOL);
   double price  = HistoryDealGetDouble(trans.deal, DEAL_PRICE);

   // Original direction of the position (deal type on close is the opposite)
   string direction = (dtype == DEAL_TYPE_SELL) ? "BUY" : "SELL";

   // Rough pip estimate from profit/lots isn't reliable across symbols,
   // so approximate via price distance isn't available here either —
   // pass profit only; the backend formats pips from entry/exit if needed.
   double pnlPips = 0;

   bool eaShouldSendTelegram = EnableTelegram && !(UseBackendBridge && BridgeSendsTelegram);

   if(reason == DEAL_REASON_SL) {
      if(UseBackendBridge) BridgePostTradeUpdate(posTicket, symbol, direction, "SL_HIT", price, pnlPips, profit);
      if(eaShouldSendTelegram && AlertOnSL) {
         SendTelegram("🔴 *STOP LOSS HIT — " + symbol + "*\n"
            + "Exit: `" + DoubleToString(price, _Digits) + "`\n"
            + "P&L: " + DoubleToString(profit, 2) + " USD\n"
            + "_Review setup. Stay disciplined. 🛡️_");
      }
   }
   if(reason == DEAL_REASON_TP) {
      if(UseBackendBridge) BridgePostTradeUpdate(posTicket, symbol, direction, "TP1_HIT", price, pnlPips, profit);
      if(eaShouldSendTelegram && AlertOnTP) {
         SendTelegram("✅ *TAKE PROFIT HIT — " + symbol + "*\n"
            + "Exit: `" + DoubleToString(price, _Digits) + "`\n"
            + "P&L: +" + DoubleToString(profit, 2) + " USD 💰\n"
            + "_Move remaining to breakeven. Let it run. ✦_");
      }
   }
}

