// ── News Filter ──────────────────────────────────────────────────────
input group "═══ News Filter ═══"
input bool     EnableNewsFilter   = true;           // Block trades near news
input int      NewsBufferMinutes  = 30;             // Minutes before/after news

// ── PropFirm Compliance ──────────────────────────────────────────────
input group "═══ PropFirm Guard ═══"
