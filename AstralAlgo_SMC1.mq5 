// Structure detection results
struct SwingPoint {
   double price;
   datetime time;
   int      bar;
   bool     isHigh;
};

struct OrderBlock {
   double   high;
   double   low;
   double   open;
   double   close;
   datetime time;
   bool     isBullish;
   bool     mitigated;
   int      strength;    // 1-3 based on impulse after OB
};

struct FairValueGap {
   double   upper;
   double   lower;
   datetime time;
   bool     isBullish;
   bool     filled;
};

struct SMCSetup {
   bool     valid;
   bool     isBull;
   double   entry;
   double   sl;
   double   tp1;
   double   tp2;
   double   tp3;
   double   rr;
   double   confidence;  // 0-100
   string   reason;
};

// Arrays for detected structures
SwingPoint   g_Swings[];
OrderBlock   g_OBs[];
FairValueGap g_FVGs[];

// Journal
int g_JournalHandle = INVALID_HANDLE;
string g_JournalFile;

//+------------------------------------------------------------------+
//|  OnInit                                                          |
//+------------------------------------------------------------------+
int OnInit()
{
   // Validate inputs
   if(RiskPercent <= 0 || RiskPercent > 5) {
      Alert("AstralAlgo: Risk % must be between 0 and 5. Check inputs.");
      return INIT_PARAMETERS_INCORRECT;
   }
   if(EnableTelegram && (TelegramToken == "" || TelegramChatID == "")) {
      Print("AstralAlgo WARNING: Telegram enabled but Token/ChatID not set.");
   }

   // Trade object setup
   Trade.SetExpertMagicNumber(Magic);
   Trade.SetDeviationInPoints(20);
   Trade.SetTypeFilling(ORDER_FILLING_IOC);
   Trade.LogLevel(LOG_LEVEL_ERRORS);

   // Account baseline
   g_StartBalance      = AccountInfoDouble(ACCOUNT_BALANCE);
   g_DailyStartBalance = g_StartBalance;
   g_DailyResetTime    = TimeCurrent();

   // Journal init
   g_JournalFile = EA_Name + "_Journal_" + TimeToString(TimeCurrent(), TIME_DATE) + ".csv";
   g_JournalHandle = FileOpen(g_JournalFile, FILE_WRITE|FILE_CSV|FILE_COMMON);
   if(g_JournalHandle != INVALID_HANDLE) {
      FileWrite(g_JournalHandle,
         "DateTime","Symbol","Direction","Entry","SL","TP1","TP2","TP3",
         "Lots","RR","Confidence","Result","PnL_Pips","PnL_USD","Reason");
   }

   // Chart setup
   if(ShowDashboard) DrawDashboard();

   Print("✦ AstralAlgo SMC EA Initialized | Balance: ", g_StartBalance,
         " | Risk: ", RiskPercent, "% | Magic: ", Magic);

   // Startup Telegram
   if(EnableTelegram) {
      string msg = "✦ *AstralAlgo SMC Engine Started*\n"
                 + "Symbol: " + _Symbol + "\n"
                 + "HTF: " + EnumToString(HTF) + " | LTF: " + EnumToString(LTF) + "\n"
                 + "Risk: " + DoubleToString(RiskPercent, 1) + "% per trade\n"
                 + "PropFirm Guard: " + (EnablePropFirm ? "✅ Active" : "❌ Off") + "\n"
                 + "Balance: $" + DoubleToString(g_StartBalance, 2);
      SendTelegram(msg);
   }

   EventSetTimer(60); // 1-min timer for session checks
   return INIT_SUCCEEDED;
}
