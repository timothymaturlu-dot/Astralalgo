//+------------------------------------------------------------------+
//|  INPUT PARAMETERS                                                |
//+------------------------------------------------------------------+

// ── General ─────────────────────────────────────────────────────────
input group "═══ General Settings ═══"
input string   EA_Name            = "AstralAlgo SMC";
input long     Magic              = 20260612;       // Unique magic number
input bool     EnableTrading      = true;           // Master on/off switch
input bool     EnableLong         = true;           // Allow BUY trades
input bool     EnableShort        = true;           // Allow SELL trades
input ENUM_TIMEFRAMES HTF         = PERIOD_H4;      // Higher timeframe for bias
input ENUM_TIMEFRAMES LTF         = PERIOD_M15;     // Lower timeframe for entry

// ── Risk & Money Management ──────────────────────────────────────────
input group "═══ Risk Management ═══"
input double   RiskPercent        = 0.5;            // Risk % per trade
input double   MinRR              = 2.0;            // Minimum reward:risk ratio
input double   MaxSpreadPoints    = 30;             // Max spread in points to enter
input int      MaxOpenTrades      = 3;              // Max concurrent positions
input bool     UseTrailingStop    = true;           // Enable trailing stop
input double   TrailStartR        = 1.0;            // Start trailing after R multiple
input double   TrailStepPoints    = 50;             // Trail step in points
input bool     UseBreakEven       = true;           // Move SL to BE at TP1
input double   BreakEvenR         = 1.0;            // BE trigger at R multiple
input double   PartialCloseR      = 1.0;            // Partial close at R multiple (0=off)
input double   PartialClosePct    = 50.0;           // % of position to close at TP1

// ── SMC / ICT Logic ─────────────────────────────────────────────────
input group "═══ SMC / ICT Parameters ═══"
input int      SwingLookback      = 20;             // Bars to identify swing H/L
input int      OB_Lookback        = 50;             // Bars to scan for Order Blocks
input int      FVG_MinGapPoints   = 20;             // Minimum FVG size in points
input double   OTE_FibLow         = 0.618;          // OTE Fib low (61.8%)
input double   OTE_FibHigh        = 0.79;           // OTE Fib high (79%)
input bool     RequireFVG         = true;           // Require FVG confluence
input bool     RequireOB          = true;           // Require Order Block confluence
input bool     RequireLiqSweep    = true;           // Require liquidity sweep
input bool     RequireCISD        = true;           // Require CISD confirmation
input int      CISDCandles        = 3;              // Candles to confirm CISD
input int      MSB_Lookback       = 10;             // Bars to confirm MSB
input bool     RequireMSB         = true;           // Require Market Structure Break

// ── Session / Kill Zone ──────────────────────────────────────────────
input group "═══ Session Filter ═══"
input bool     LondonKZ           = true;           // Trade London Kill Zone
input int      LondonStartHr      = 7;              // London KZ start (server time hr)
input int      LondonEndHr        = 10;             // London KZ end
input bool     NewYorkKZ          = true;           // Trade New York Kill Zone
input int      NYStartHr          = 12;             // NY KZ start
input int      NYEndHr            = 15;             // NY KZ end
input bool     LondonCloseKZ      = false;          // Trade London Close KZ
input int      LCStartHr          = 15;             // London Close start
input int      LCEndHr            = 17;             // London Close end
input bool     AsianKZ            = false;          // Trade Asian Kill Zone
