//+------------------------------------------------------------------+
//|  TELEGRAM                                                        |
//+------------------------------------------------------------------+
void SendTelegram(string message)
{
   if(!EnableTelegram || TelegramToken == "" || TelegramChatID == "") return;

   string url     = "https://api.telegram.org/bot" + TelegramToken + "/sendMessage";
   string headers = "Content-Type: application/x-www-form-urlencoded\r\n";
   string body    = "chat_id=" + TelegramChatID
                  + "&text=" + EncodeURL(message)
                  + "&parse_mode=Markdown";

   char   req[], res[];
   string resHeaders;
   StringToCharArray(body, req, 0, StringLen(body));

   int code = WebRequest("POST", url, headers, 10000, req, res, resHeaders);
   if(code != 200)
      Print("AstralAlgo Telegram error: HTTP ", code, " | ", CharArrayToString(res));
}

string EncodeURL(string text)
{
   // Basic URL encoding for Telegram
   StringReplace(text, " ",  "%20");
   StringReplace(text, "\n", "%0A");
   StringReplace(text, "*",  "%2A");
   StringReplace(text, "`",  "%60");
   StringReplace(text, "_",  "%5F");
   StringReplace(text, "#",  "%23");
   StringReplace(text, "&",  "%26");
   StringReplace(text, "=",  "%3D");
   StringReplace(text, "+",  "%2B");
   return text;
}

//+------------------------------------------------------------------+
//|  BACKEND BRIDGE                                                  |
//|  Posts signals and trade updates to main.py (FastAPI backend).   |
//|  The backend — not the EA — sends Telegram when BridgeSendsTelegram|
//|  is true, so the subscriber group only ever gets ONE message per |
//|  event instead of duplicates from both EA and backend.           |
//+------------------------------------------------------------------+

string JsonEscape(string text)
{
   // Escape characters that would break a JSON string literal
   StringReplace(text, "\\", "\\\\");
   StringReplace(text, "\"", "\\\"");
   StringReplace(text, "\n", "\\n");
   StringReplace(text, "\r", "");
   StringReplace(text, "\t", " ");
   return text;
}

// Record which backend signal_id corresponds to a given MT5 ticket,
// so a later TP/SL/close event can tell the backend which row to update.
void BridgeRememberTicket(ulong ticket, string signalId)
{
   int n = ArraySize(g_BridgeTickets);
   ArrayResize(g_BridgeTickets,  n + 1);
   ArrayResize(g_BridgeSignalIds, n + 1);
   g_BridgeTickets[n]   = ticket;
   g_BridgeSignalIds[n] = signalId;
}

string BridgeLookupSignalId(ulong ticket)
{
   for(int i = 0; i < ArraySize(g_BridgeTickets); i++) {
      if(g_BridgeTickets[i] == ticket) return g_BridgeSignalIds[i];
   }
   return "";
}

// ── POST /ea/signal — called right after a trade is opened ───────────
// Returns the backend's signal_id (empty string on failure) so it can
// be linked to this ticket for trade-update calls later.
string BridgePostSignal(SMCSetup &setup, double lots, ulong ticket)
{
   if(!UseBackendBridge || BackendURL == "") return "";

   string url = BackendURL + "/ea/signal";

   string body = StringFormat(
      "{\"symbol\":\"%s\",\"direction\":\"%s\","
      "\"entry\":%.5f,\"sl\":%.5f,\"tp1\":%.5f,\"tp2\":%.5f,\"tp3\":%.5f,"
      "\"lots\":%.2f,\"rr\":%.2f,\"confidence\":%.1f,"
      "\"session\":\"%s\",\"confluences\":\"%s\",\"magic\":%d,"
      "\"account_size\":%.2f,\"risk_pct\":%.2f,\"propfirm_mode\":%s}",
      _Symbol,
      setup.isBull ? "BUY" : "SELL",
      setup.entry, setup.sl, setup.tp1, setup.tp2, setup.tp3,
      lots, setup.rr, setup.confidence,
      GetCurrentSession(), JsonEscape(setup.reason), (int)Magic,
      AccountInfoDouble(ACCOUNT_BALANCE), RiskPercent,
      EnablePropFirm ? "true" : "false"
   );

   string headers = "Content-Type: application/json\r\n"
                   + "X-EA-Secret: " + EA_Secret + "\r\n";

   char   req[], res[];
   string resHeaders;
   StringToCharArray(body, req, 0, StringLen(body));

   ResetLastError();
   int code = WebRequest("POST", url, headers, BridgeTimeoutMs, req, res, resHeaders);

   if(code == -1) {
      int err = GetLastError();
      Print("AstralAlgo Bridge: WebRequest failed (err ", err,
            "). Add ", BackendURL, " to Tools > Options > Expert Advisors > Allow WebRequest.");
      return "";
   }
   if(code != 200) {
      Print("AstralAlgo Bridge: /ea/signal returned HTTP ", code, " | ", CharArrayToString(res));
      return "";
   }

   string response = CharArrayToString(res);

   // Extract "signal_id":"..." from the JSON response without a full parser
   string signalId = "";
   int idPos = StringFind(response, "\"signal_id\":\"");
   if(idPos >= 0) {
      idPos += 13;
      int idEnd = StringFind(response, "\"", idPos);
      if(idEnd > idPos) signalId = StringSubstr(response, idPos, idEnd - idPos);
   }

   if(signalId != "") {
      BridgeRememberTicket(ticket, signalId);
      Print("AstralAlgo Bridge: signal posted -> ", signalId);
   } else {
      Print("AstralAlgo Bridge: signal posted but no signal_id returned (DB may be unconfigured)");
   }

   return signalId;
}

// ── POST /ea/trade-update — called on TP/SL/partial/close ────────────
void BridgePostTradeUpdate(ulong ticket, string symbol, string direction, string status,
                            double exitPrice, double pnlPips, double pnlUsd)
{
   if(!UseBackendBridge || BackendURL == "") return;

   string url = BackendURL + "/ea/trade-update";
   string signalId = BridgeLookupSignalId(ticket);

   string body = StringFormat(
      "{\"signal_id\":%s,\"ticket\":%I64u,\"symbol\":\"%s\",\"direction\":\"%s\","
      "\"status\":\"%s\",\"exit_price\":%.5f,\"pnl_pips\":%.1f,\"pnl_usd\":%.2f,\"magic\":%d}",
      signalId == "" ? "null" : ("\"" + signalId + "\""),
      ticket, symbol, direction, status, exitPrice, pnlPips, pnlUsd, (int)Magic
   );

   string headers = "Content-Type: application/json\r\n"
                   + "X-EA-Secret: " + EA_Secret + "\r\n";

   char   req[], res[];
   string resHeaders;
   StringToCharArray(body, req, 0, StringLen(body));

   ResetLastError();
   int code = WebRequest("POST", url, headers, BridgeTimeoutMs, req, res, resHeaders);

   if(code == -1) {
      Print("AstralAlgo Bridge: trade-update WebRequest failed (err ", GetLastError(), ")");
      return;
   }
   if(code != 200) {
      Print("AstralAlgo Bridge: /ea/trade-update returned HTTP ", code);
      return;
   }
   Print("AstralAlgo Bridge: trade-update sent -> ", status, " | ticket #", ticket);
}

// ── POST /ea/heartbeat — periodic liveness ping ───────────────────────
void BridgePostHeartbeat()
{
   if(!UseBackendBridge || BackendURL == "") return;

   string url = BackendURL + "/ea/heartbeat";
   string body = StringFormat(
      "{\"magic\":%d,\"symbol\":\"%s\",\"uptime_sec\":%d,\"in_session\":%s,\"bias\":\"%s\",\"spread\":%.1f}",
      (int)Magic, _Symbol,
      (int)(TimeCurrent() - g_DailyResetTime),
      InKillZone() ? "true" : "false",
      g_BullishBias ? "BULLISH" : (g_BearishBias ? "BEARISH" : "NEUTRAL"),
      (double)SymbolInfoInteger(_Symbol, SYMBOL_SPREAD)
   );

   string headers = "Content-Type: application/json\r\n" + "X-EA-Secret: " + EA_Secret + "\r\n";
   char   req[], res[];
   string resHeaders;
   StringToCharArray(body, req, 0, StringLen(body));

   ResetLastError();
   WebRequest("POST", url, headers, BridgeTimeoutMs, req, res, resHeaders);
   // Heartbeat failures are non-critical — no alert needed, just skip silently
}

void SendDailySummary()
{
   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   double equity  = AccountInfoDouble(ACCOUNT_EQUITY);
   double dailyPnL = balance - g_DailyStartBalance;
   double dailyPct = dailyPnL / g_DailyStartBalance * 100.0;
   double totalDD  = (g_StartBalance - equity) / g_StartBalance * 100.0;

   string msg = "📊 *Astral Algo — Daily Summary*\n\n"
      + "💰 Balance: $" + DoubleToString(balance, 2) + "\n"
      + "📈 Daily P&L: " + (dailyPnL >= 0 ? "+" : "") + DoubleToString(dailyPnL, 2)
                        + " (" + (dailyPct >= 0 ? "+" : "") + DoubleToString(dailyPct, 2) + "%)\n"
      + "📉 Total DD: -" + DoubleToString(totalDD, 2) + "%\n"
      + "🎯 Signals: " + IntegerToString(g_SigCount) + " today\n"
      + "🛡️ PropFirm: " + (PassPropFirmGuard() ? "✅ Compliant" : "⚠️ Check limits") + "\n"
      + "_— Astral Algo © 2026_";
   SendTelegram(msg);
}

