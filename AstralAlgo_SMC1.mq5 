//+------------------------------------------------------------------+
//|  OnInit                                                          |
//+------------------------------------------------------------------+
int OnInit()
{
   // Validate inputs
   if(RiskPercent <= 0 || RiskPercent > 5) {
      Alert("AstralAlgo: Risk % must be between 0 and 5. Check inputs.");
      return INIT_PARAMETERS_INCORRECT;
   }
   if(EnableTelegram && (TelegramToken == "" || TelegramChatID == "")) {
      Print("AstralAlgo WARNING: Telegram enabled but Token/ChatID not set.");
   }

   // Trade object setup
   Trade.SetExpertMagicNumber(Magic);
   Trade.SetDeviationInPoints(20);
   Trade.SetTypeFilling(ORDER_FILLING_IOC);
   Trade.LogLevel(LOG_LEVEL_ERRORS);

   // Account baseline
   g_StartBalance      = AccountInfoDouble(ACCOUNT_BALANCE);
   g_DailyStartBalance = g_StartBalance;
   g_DailyResetTime    = TimeCurrent();

   // Journal init
   g_JournalFile = EA_Name + "_Journal_" + TimeToString(TimeCurrent(), TIME_DATE) + ".csv";
   g_JournalHandle = FileOpen(g_JournalFile, FILE_WRITE|FILE_CSV|FILE_COMMON);
   if(g_JournalHandle != INVALID_HANDLE) {
      FileWrite(g_JournalHandle,
         "DateTime","Symbol","Direction","Entry","SL","TP1","TP2","TP3",
         "Lots","RR","Confidence","Result","PnL_Pips","PnL_USD","Reason");
   }

   // Chart setup
   if(ShowDashboard) DrawDashboard();

   Print("✦ AstralAlgo SMC EA Initialized | Balance: ", g_StartBalance,
         " | Risk: ", RiskPercent, "% | Magic: ", Magic);

   // Startup Telegram
   if(EnableTelegram) {
      string msg = "✦ *AstralAlgo SMC Engine Started*\n"
                 + "Symbol: " + _Symbol + "\n"
                 + "HTF: " + EnumToString(HTF) + " | LTF: " + EnumToString(LTF) + "\n"
                 + "Risk: " + DoubleToString(RiskPercent, 1) + "% per trade\n"
                 + "PropFirm Guard: " + (EnablePropFirm ? "✅ Active" : "❌ Off") + "\n"
                 + "Balance: $" + DoubleToString(g_StartBalance, 2);
      SendTelegram(msg);
   }

   EventSetTimer(60); // 1-min timer for session checks
   return INIT_SUCCEEDED;
}

//+------------------------------------------------------------------+
//|  OnDeinit                                                        |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   EventKillTimer();
   ObjectsDeleteAll(0, "AA_");
   if(g_JournalHandle != INVALID_HANDLE) FileClose(g_JournalHandle);

   if(EnableTelegram) {
      string msg = "⚠️ *AstralAlgo EA Stopped*\n"
                 + "Reason: " + IntegerToString(reason) + "\n"
                 + "Final Balance: $" + DoubleToString(AccountInfoDouble(ACCOUNT_BALANCE), 2);
      SendTelegram(msg);
   }
}

//+------------------------------------------------------------------+
//|  OnTick — Main Loop                                              |
//+------------------------------------------------------------------+
void OnTick()
{
   // Only process on new bar (LTF)
   datetime currentBar = iTime(_Symbol, LTF, 0);
   if(currentBar == g_LastBarTime) return;
   g_LastBarTime = currentBar;

   // ── 1. Daily reset ──────────────────────────────────────────────
   CheckDailyReset();

   // ── 2. PropFirm guard ───────────────────────────────────────────
   if(EnablePropFirm && !PassPropFirmGuard()) return;

   // ── 3. Master switch ────────────────────────────────────────────
   if(!EnableTrading) return;

   // ── 4. Manage open positions ────────────────────────────────────
   ManageOpenPositions();

   // ── 5. Session / Kill Zone check ────────────────────────────────
   if(!InKillZone()) return;

   // ── 6. Friday filter ────────────────────────────────────────────
   if(NoTradeOnFriday && IsFridayBlock()) return;

   // ── 7. Spread check ─────────────────────────────────────────────
   if(!SpreadOK()) return;

   // ── 8. Max trades check ─────────────────────────────────────────
   if(CountMyPositions() >= MaxOpenTrades) return;

   // ── 9. HTF Bias ─────────────────────────────────────────────────
   DetectHTFBias();

   // ── 10. Scan for SMC setup ──────────────────────────────────────
   DetectSwingPoints();
   DetectOrderBlocks();
   DetectFairValueGaps();

   SMCSetup setup = EvaluateSetup();
   if(!setup.valid) return;

   // ── 11. Execute trade ───────────────────────────────────────────
   ExecuteTrade(setup);
}

//+------------------------------------------------------------------+
//|  OnTimer — Periodic tasks                                        |
//+------------------------------------------------------------------+
void OnTimer()
{
   // Friday close
   if(CloseAllFriday && DayOfWeek() == FRIDAY) {
      MqlDateTime dt; TimeToStruct(TimeCurrent(), dt);
      if(dt.hour >= FridayCloseHr) CloseAllPositions("Friday close");
   }

   // Refresh dashboard
   if(ShowDashboard) DrawDashboard();

   // Backend heartbeat — lets main.py (and your website) know the EA is alive
   if(UseBackendBridge) BridgePostHeartbeat();

   // Daily summary (send at 23:50) — only the EA's own version; if the
   // bridge is active with BridgeSendsTelegram on, the backend sends its
   // own richer daily summary instead, so skip here to avoid duplicates.
   bool eaOwnsDailySummary = EnableTelegram && AlertOnDailySum
                             && !(UseBackendBridge && BridgeSendsTelegram);
   if(eaOwnsDailySummary) {
      MqlDateTime dt; TimeToStruct(TimeCurrent(), dt);
      if(dt.hour == 23 && dt.min == 50) SendDailySummary();
   }
}

//+------------------------------------------------------------------+
//|  HTF BIAS DETECTION                                              |
//|  Reads D1 / H4 structure to determine directional bias           |
//+------------------------------------------------------------------+
void DetectHTFBias()
{
   // Collect last N HTF candles
   int bars = 50;
   double highs[], lows[], closes[];
   ArraySetAsSeries(highs,  true);
   ArraySetAsSeries(lows,   true);
   ArraySetAsSeries(closes, true);
   CopyHigh(_Symbol, HTF, 0, bars, highs);
   CopyLow (_Symbol, HTF, 0, bars, lows);
   CopyClose(_Symbol, HTF, 0, bars, closes);

   // Higher High / Higher Low = Bullish
   // Lower Low / Lower High = Bearish
   // Compare last 3 swing structure
   double prevSwingHigh = 0, prevSwingLow = DBL_MAX;
   double currSwingHigh = 0, currSwingLow = DBL_MAX;

   // Find most recent swing high and low in HTF
   for(int i = 2; i < bars - 2; i++) {
      // Swing High: higher than 2 bars each side
      if(highs[i] > highs[i-1] && highs[i] > highs[i+1] &&
         highs[i] > highs[i-2] && highs[i] > highs[i+2]) {
         if(currSwingHigh == 0)      currSwingHigh = highs[i];
         else if(prevSwingHigh == 0) { prevSwingHigh = highs[i]; }
      }
      // Swing Low
      if(lows[i] < lows[i-1] && lows[i] < lows[i+1] &&
         lows[i] < lows[i-2] && lows[i] < lows[i+2]) {
         if(currSwingLow == DBL_MAX)      currSwingLow = lows[i];
         else if(prevSwingLow == DBL_MAX) { prevSwingLow = lows[i]; }
      }
      if(prevSwingHigh > 0 && prevSwingLow < DBL_MAX) break;
   }

   // EMA 50 & 200 on HTF for additional confirmation
   double ema50[], ema200[];
   ArraySetAsSeries(ema50,  true);
   ArraySetAsSeries(ema200, true);
   int ema50Handle  = iMA(_Symbol, HTF, 50,  0, MODE_EMA, PRICE_CLOSE);
   int ema200Handle = iMA(_Symbol, HTF, 200, 0, MODE_EMA, PRICE_CLOSE);
   CopyBuffer(ema50Handle,  0, 0, 3, ema50);
   CopyBuffer(ema200Handle, 0, 0, 3, ema200);
   IndicatorRelease(ema50Handle);
   IndicatorRelease(ema200Handle);

   bool emaBull = (ema50[0] > ema200[0]);
   bool emaHHHL = (currSwingHigh > prevSwingHigh && currSwingLow > prevSwingLow);
   bool emaLLLH = (currSwingHigh < prevSwingHigh && currSwingLow < prevSwingLow);

   // Require both structure AND EMA alignment
   g_BullishBias = emaHHHL && emaBull;
   g_BearishBias = emaLLLH && !emaBull;

   // Override: neutral if conflicting
   if(g_BullishBias && g_BearishBias) {
      g_BullishBias = false;
      g_BearishBias = false;
   }
}

//+------------------------------------------------------------------+
//|  SWING POINT DETECTION                                           |
//|  Identifies significant swing highs and lows on LTF              |
//+------------------------------------------------------------------+
void DetectSwingPoints()
{
   ArrayResize(g_Swings, 0);
   int lookback = SwingLookback;

   double highs[], lows[];
   datetime times[];
   ArraySetAsSeries(highs, true);
   ArraySetAsSeries(lows,  true);
   ArraySetAsSeries(times, true);
   CopyHigh(_Symbol, LTF, 0, lookback + 5, highs);
   CopyLow (_Symbol, LTF, 0, lookback + 5, lows);
   CopyTime(_Symbol, LTF, 0, lookback + 5, times);

   int idx = ArraySize(g_Swings);

   for(int i = 2; i < lookback - 2; i++) {
      bool isSwingHigh = highs[i] > highs[i-1] && highs[i] > highs[i+1]
                      && highs[i] > highs[i-2] && highs[i] > highs[i+2];
      bool isSwingLow  = lows[i]  < lows[i-1]  && lows[i]  < lows[i+1]
                      && lows[i]  < lows[i-2]  && lows[i]  < lows[i+2];

      if(isSwingHigh || isSwingLow) {
         ArrayResize(g_Swings, idx + 1);
         g_Swings[idx].price  = isSwingHigh ? highs[i] : lows[i];
         g_Swings[idx].time   = times[i];
         g_Swings[idx].bar    = i;
         g_Swings[idx].isHigh = isSwingHigh;
         idx++;
      }
   }

   // Draw swing points on chart
   if(ShowSwingPoints) {
      ObjectsDeleteAll(0, "AA_SW_");
      for(int i = 0; i < ArraySize(g_Swings); i++) {
         string name = "AA_SW_" + IntegerToString(i);
         ObjectCreate(0, name, OBJ_ARROW, 0, g_Swings[i].time, g_Swings[i].price);
         ObjectSetInteger(0, name, OBJPROP_ARROWCODE, g_Swings[i].isHigh ? 218 : 217);
         ObjectSetInteger(0, name, OBJPROP_COLOR, Swing_Color);
         ObjectSetInteger(0, name, OBJPROP_WIDTH, 2);
      }
   }
}

//+------------------------------------------------------------------+
//|  MARKET STRUCTURE BREAK DETECTION                                |
//|  A MSB occurs when price closes beyond a swing high/low          |
//+------------------------------------------------------------------+
bool DetectMSB(bool forBull)
{
   if(ArraySize(g_Swings) < 2) return false;

   double closes[];
   ArraySetAsSeries(closes, true);
   CopyClose(_Symbol, LTF, 0, MSB_Lookback + 2, closes);

   // For bull MSB: recent close above previous swing high
   // For bear MSB: recent close below previous swing low
   for(int i = 0; i < ArraySize(g_Swings); i++) {
      if(forBull && !g_Swings[i].isHigh) continue;
      if(!forBull && g_Swings[i].isHigh) continue;

      double level = g_Swings[i].price;
      // Check if any of last MSB_Lookback closes broke this level
      for(int b = 1; b <= MathMin(MSB_Lookback, ArraySize(closes)-1); b++) {
         if(forBull && closes[b] > level)  return true;
         if(!forBull && closes[b] < level) return true;
      }
      break; // Only check most recent relevant swing
   }
   return false;
}

//+------------------------------------------------------------------+
//|  ORDER BLOCK DETECTION                                           |
//|  Last bearish candle before bullish impulse = Bullish OB         |
//|  Last bullish candle before bearish impulse = Bearish OB         |
//+------------------------------------------------------------------+
void DetectOrderBlocks()
{
   ArrayResize(g_OBs, 0);
   int lookback = OB_Lookback;

   double opens[], highs[], lows[], closes[];
   datetime times[];
   ArraySetAsSeries(opens,  true);
   ArraySetAsSeries(highs,  true);
   ArraySetAsSeries(lows,   true);
   ArraySetAsSeries(closes, true);
   ArraySetAsSeries(times,  true);

   CopyOpen (_Symbol, LTF, 0, lookback, opens);
   CopyHigh (_Symbol, LTF, 0, lookback, highs);
   CopyLow  (_Symbol, LTF, 0, lookback, lows);
   CopyClose(_Symbol, LTF, 0, lookback, closes);
   CopyTime (_Symbol, LTF, 0, lookback, times);

   int idx = 0;
   double minImpulse = 3 * _Point * 100; // Minimum 3-pip impulse to qualify

   for(int i = 3; i < lookback - 3; i++) {

      // ── Bullish OB: bearish candle before strong bullish move ────
      bool prevBear = closes[i] < opens[i];
      // Impulse: next 3 candles move strongly upward
      double impulseUp = closes[i-1] - closes[i];
      if(prevBear && impulseUp > minImpulse) {
         bool strongImpulse = (closes[i-2] > highs[i]) || (closes[i-3] > highs[i]);
         if(strongImpulse) {
            ArrayResize(g_OBs, idx + 1);
            g_OBs[idx].high      = highs[i];
            g_OBs[idx].low       = lows[i];
            g_OBs[idx].open      = opens[i];
            g_OBs[idx].close     = closes[i];
            g_OBs[idx].time      = times[i];
            g_OBs[idx].isBullish = true;
            g_OBs[idx].mitigated = (lows[0] < lows[i]); // Mitigated if price went below
            g_OBs[idx].strength  = strongImpulse ? 3 : 2;
            idx++;
         }
      }

      // ── Bearish OB: bullish candle before strong bearish move ────
      bool prevBull = closes[i] > opens[i];
      double impulseDown = closes[i] - closes[i-1];
      if(prevBull && impulseDown > minImpulse) {
         bool strongImpulse = (closes[i-2] < lows[i]) || (closes[i-3] < lows[i]);
         if(strongImpulse) {
            ArrayResize(g_OBs, idx + 1);
            g_OBs[idx].high      = highs[i];
            g_OBs[idx].low       = lows[i];
            g_OBs[idx].open      = opens[i];
            g_OBs[idx].close     = closes[i];
            g_OBs[idx].time      = times[i];
            g_OBs[idx].isBullish = false;
            g_OBs[idx].mitigated = (highs[0] > highs[i]);
            g_OBs[idx].strength  = strongImpulse ? 3 : 2;
            idx++;
         }
      }
   }

   // Draw OB zones
   if(ShowOBZones) {
      ObjectsDeleteAll(0, "AA_OB_");
      for(int i = 0; i < ArraySize(g_OBs); i++) {
         if(g_OBs[i].mitigated) continue;
         string name = "AA_OB_" + IntegerToString(i);
         datetime t2 = TimeCurrent() + PeriodSeconds(LTF) * 30;
         ObjectCreate(0, name, OBJ_RECTANGLE, 0, g_OBs[i].time, g_OBs[i].high, t2, g_OBs[i].low);
         ObjectSetInteger(0, name, OBJPROP_COLOR,   g_OBs[i].isBullish ? BullOB_Color : BearOB_Color);
         ObjectSetInteger(0, name, OBJPROP_STYLE,   STYLE_SOLID);
         ObjectSetInteger(0, name, OBJPROP_WIDTH,   1);
         ObjectSetInteger(0, name, OBJPROP_FILL,    true);
         ObjectSetDouble (0, name, OBJPROP_TRANSPARENCY, 85);
         ObjectSetString (0, name, OBJPROP_TOOLTIP,
            (g_OBs[i].isBullish ? "Bullish" : "Bearish") + " OB | Str: " + IntegerToString(g_OBs[i].strength));
      }
   }
}

//+------------------------------------------------------------------+
//|  FAIR VALUE GAP DETECTION                                        |
//|  3-candle pattern where candle 1 high < candle 3 low (bullish)   |
//|  or candle 1 low > candle 3 high (bearish)                       |
//+------------------------------------------------------------------+
void DetectFairValueGaps()
{
   ArrayResize(g_FVGs, 0);
   int lookback = 60;

   double highs[], lows[];
   datetime times[];
   ArraySetAsSeries(highs, true);
   ArraySetAsSeries(lows,  true);
   ArraySetAsSeries(times, true);
   CopyHigh(_Symbol, LTF, 0, lookback, highs);
   CopyLow (_Symbol, LTF, 0, lookback, lows);
   CopyTime(_Symbol, LTF, 0, lookback, times);

   double minGap = FVG_MinGapPoints * _Point;
   int idx = 0;

   for(int i = 1; i < lookback - 2; i++) {
      // Bullish FVG: candle[i+1].high < candle[i-1].low → gap above
      double bullGap = lows[i-1] - highs[i+1];
      if(bullGap > minGap) {
         ArrayResize(g_FVGs, idx + 1);
         g_FVGs[idx].upper     = lows[i-1];
         g_FVGs[idx].lower     = highs[i+1];
         g_FVGs[idx].time      = times[i];
         g_FVGs[idx].isBullish = true;
         g_FVGs[idx].filled    = (lows[0] < highs[i+1]); // Filled if price dropped in
         idx++;
      }

      // Bearish FVG: candle[i+1].low > candle[i-1].high → gap below
      double bearGap = lows[i+1] - highs[i-1];
      if(bearGap > minGap) {
         ArrayResize(g_FVGs, idx + 1);
         g_FVGs[idx].upper     = lows[i+1];
         g_FVGs[idx].lower     = highs[i-1];
         g_FVGs[idx].time      = times[i];
         g_FVGs[idx].isBullish = false;
         g_FVGs[idx].filled    = (highs[0] > lows[i+1]);
         idx++;
      }
   }

   // Draw FVG zones
   if(ShowFVGZones) {
      ObjectsDeleteAll(0, "AA_FVG_");
      for(int i = 0; i < ArraySize(g_FVGs); i++) {
         if(g_FVGs[i].filled) continue;
         string name = "AA_FVG_" + IntegerToString(i);
         datetime t2 = TimeCurrent() + PeriodSeconds(LTF) * 20;
         ObjectCreate(0, name, OBJ_RECTANGLE, 0, g_FVGs[i].time, g_FVGs[i].upper, t2, g_FVGs[i].lower);
         ObjectSetInteger(0, name, OBJPROP_COLOR,        FVG_Color);
         ObjectSetInteger(0, name, OBJPROP_FILL,         true);
         ObjectSetDouble (0, name, OBJPROP_TRANSPARENCY, 88);
         ObjectSetString (0, name, OBJPROP_TOOLTIP,
            (g_FVGs[i].isBullish ? "Bullish" : "Bearish") + " FVG | Gap: "
            + DoubleToString((g_FVGs[i].upper - g_FVGs[i].lower) / _Point, 0) + " pts");
      }
   }
}

//+------------------------------------------------------------------+
//|  LIQUIDITY SWEEP DETECTION                                       |
//|  Price wicks above swing high (BSL sweep) or below swing low     |
//+------------------------------------------------------------------+
bool DetectLiquiditySweep(bool forBull)
{
   if(ArraySize(g_Swings) < 1) return false;

   double highs[], lows[];
   ArraySetAsSeries(highs, true);
   ArraySetAsSeries(lows,  true);
   CopyHigh(_Symbol, LTF, 0, 10, highs);
   CopyLow (_Symbol, LTF, 0, 10, lows);

   double close1 = iClose(_Symbol, LTF, 1);

   for(int i = 0; i < ArraySize(g_Swings); i++) {
      double level = g_Swings[i].price;

      if(forBull && !g_Swings[i].isHigh) {
         // Bullish setup needs sweep of a SELL-SIDE liquidity (swing low)
         // Wick went below it but closed back above
         bool swept = false;
         for(int b = 1; b <= 5; b++) {
            if(lows[b] < level) { swept = true; break; }
         }
         bool closedAbove = close1 > level;
         if(swept && closedAbove) return true;
      }

      if(!forBull && g_Swings[i].isHigh) {
         // Bearish setup needs sweep of BUY-SIDE liquidity (swing high)
         bool swept = false;
         for(int b = 1; b <= 5; b++) {
            if(highs[b] > level) { swept = true; break; }
         }
         bool closedBelow = close1 < level;
         if(swept && closedBelow) return true;
      }
   }
   return false;
}

//+------------------------------------------------------------------+
//|  CISD — CHANGE IN STATE OF DELIVERY                              |
//|  After a liquidity sweep, price delivers opposite direction       |
//|  Confirmed by CISDCandles consecutive candles in new direction    |
//+------------------------------------------------------------------+
bool DetectCISD(bool forBull)
{
   double opens[], closes[];
   ArraySetAsSeries(opens,  true);
   ArraySetAsSeries(closes, true);
   CopyOpen (_Symbol, LTF, 0, CISDCandles + 2, opens);
   CopyClose(_Symbol, LTF, 0, CISDCandles + 2, closes);

   int confirmCount = 0;
   for(int i = 1; i <= CISDCandles; i++) {
      bool bullCandle = closes[i] > opens[i];
      bool bearCandle = closes[i] < opens[i];
      if(forBull  && bullCandle) confirmCount++;
      if(!forBull && bearCandle) confirmCount++;
   }
   return (confirmCount >= (int)MathCeil(CISDCandles * 0.67)); // 67% of candles confirm
}

//+------------------------------------------------------------------+
//|  OTE — OPTIMAL TRADE ENTRY (Fibonacci)                           |
//|  Entry is valid when price retraces into 61.8–79% of last swing  |
//+------------------------------------------------------------------+
bool PriceInOTE(bool forBull, double &oteHigh, double &oteLow)
{
   if(ArraySize(g_Swings) < 2) return false;

   double swHigh = 0, swLow = DBL_MAX;

   // Find most recent swing high and low
   for(int i = 0; i < ArraySize(g_Swings); i++) {
      if(g_Swings[i].isHigh && swHigh == 0)       swHigh = g_Swings[i].price;
      if(!g_Swings[i].isHigh && swLow == DBL_MAX) swLow  = g_Swings[i].price;
      if(swHigh > 0 && swLow < DBL_MAX) break;
   }
   if(swHigh == 0 || swLow == DBL_MAX) return false;

   double range = swHigh - swLow;
   double ask   = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid   = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   if(forBull) {
      // Price should be retracing down into the OTE zone
      oteLow  = swHigh - range * OTE_FibHigh;  // 79% retrace
      oteHigh = swHigh - range * OTE_FibLow;   // 61.8% retrace
      return (ask >= oteLow && ask <= oteHigh);
   } else {
      // Price retracing up into OTE zone
      oteHigh = swLow + range * OTE_FibHigh;
      oteLow  = swLow + range * OTE_FibLow;
      return (bid >= oteLow && bid <= oteHigh);
   }
}

//+------------------------------------------------------------------+
//|  FULL SETUP EVALUATION                                           |
//|  Combines all SMC confluences and scores the trade               |
//+------------------------------------------------------------------+
SMCSetup EvaluateSetup()
{
   SMCSetup setup;
   setup.valid      = false;
   setup.confidence = 0;
   setup.reason     = "";

   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   bool tryBull = g_BullishBias && EnableLong;
   bool tryBear = g_BearishBias && EnableShort;

   if(!tryBull && !tryBear) return setup; // No bias

   // ── Run checks for each direction ──────────────────────────────
   for(int dir = 0; dir < 2; dir++) {
      bool isBull = (dir == 0);
      if(isBull  && !tryBull) continue;
      if(!isBull && !tryBear) continue;

      double score   = 0;
      string reasons = "";

      // 1. HTF Bias (mandatory)
      score += 20; reasons += "HTF Bias ✓ | ";

      // 2. MSB (optional but weighted)
      if(RequireMSB) {
         if(!DetectMSB(isBull)) continue; // Skip if required and not found
         score += 15; reasons += "MSB ✓ | ";
      } else if(DetectMSB(isBull)) {
         score += 10; reasons += "MSB ✓ | ";
      }

      // 3. Liquidity Sweep
      bool liqSwept = DetectLiquiditySweep(isBull);
      if(RequireLiqSweep && !liqSwept) continue;
      if(liqSwept) { score += 20; reasons += "Liq Sweep ✓ | "; }

      // 4. CISD
      bool cisd = DetectCISD(isBull);
      if(RequireCISD && !cisd) continue;
      if(cisd) { score += 15; reasons += "CISD ✓ | "; }

      // 5. OTE (Fibonacci)
      double oteH, oteL;
      bool inOTE = PriceInOTE(isBull, oteH, oteL);
      if(inOTE) { score += 15; reasons += "OTE ✓ | "; }

      // 6. Order Block confluence
      bool obConf = false;
      double obEntry = 0, obSL = 0;
      for(int i = 0; i < ArraySize(g_OBs); i++) {
         if(g_OBs[i].mitigated)              continue;
         if(g_OBs[i].isBullish != isBull)    continue;
         double price = isBull ? ask : bid;
         // Price inside or touching OB
         if(price >= g_OBs[i].low && price <= g_OBs[i].high) {
            obConf  = true;
            obEntry = isBull ? g_OBs[i].high : g_OBs[i].low;
            obSL    = isBull ? g_OBs[i].low  : g_OBs[i].high;
            score  += 10 * g_OBs[i].strength;
            reasons += "OB(Str:" + IntegerToString(g_OBs[i].strength) + ") ✓ | ";
            break;
         }
      }
      if(RequireOB && !obConf) continue;

      // 7. FVG confluence
      bool fvgConf = false;
      double fvgEntry = 0;
      for(int i = 0; i < ArraySize(g_FVGs); i++) {
         if(g_FVGs[i].filled)              continue;
         if(g_FVGs[i].isBullish != isBull) continue;
         double price = isBull ? ask : bid;
         if(price >= g_FVGs[i].lower && price <= g_FVGs[i].upper) {
            fvgConf  = true;
            fvgEntry = (g_FVGs[i].upper + g_FVGs[i].lower) / 2;
            score   += 15;
            reasons += "FVG ✓ | ";
            break;
         }
      }
      if(RequireFVG && !fvgConf) continue;

      // ── Minimum score threshold ─────────────────────────────────
      if(score < 50) continue; // Must have meaningful confluence

      // ── Determine Entry, SL, TPs ─────────────────────────────────
      double entryPrice, slPrice;

      if(obConf) {
         entryPrice = obEntry;
         slPrice    = obSL - (isBull ? 5 : -5) * _Point; // Small buffer beyond OB
      } else {
         entryPrice = isBull ? ask : bid;
         // SL below most recent swing low / above swing high
         slPrice = 0;
         for(int i = 0; i < ArraySize(g_Swings); i++) {
            if(isBull && !g_Swings[i].isHigh) {
               slPrice = g_Swings[i].price - 10 * _Point;
               break;
            }
            if(!isBull && g_Swings[i].isHigh) {
               slPrice = g_Swings[i].price + 10 * _Point;
               break;
            }
         }
         if(slPrice == 0) continue; // No valid SL found
      }

      double slDistance = MathAbs(entryPrice - slPrice);
      if(slDistance < 50 * _Point) continue; // SL too tight — skip

      // RR check
      double rr = (slDistance * MinRR); // Minimum TP distance
      if(isBull) {
         setup.tp1 = entryPrice + rr * TP1_R / MinRR;
         setup.tp2 = entryPrice + rr * TP2_R / MinRR;
         setup.tp3 = entryPrice + rr * TP3_R / MinRR;
      } else {
         setup.tp1 = entryPrice - rr * TP1_R / MinRR;
         setup.tp2 = entryPrice - rr * TP2_R / MinRR;
         setup.tp3 = entryPrice - rr * TP3_R / MinRR;
      }

      double realRR = MathAbs(setup.tp2 - entryPrice) / slDistance;
      if(realRR < MinRR) continue;

      // ── Valid setup found ────────────────────────────────────────
      setup.valid      = true;
      setup.isBull     = isBull;
      setup.entry      = entryPrice;
      setup.sl         = slPrice;
      setup.rr         = realRR;
      setup.confidence = MathMin(score, 100);
      setup.reason     = reasons;

      break; // Take first valid direction
   }

   return setup;
}

//+------------------------------------------------------------------+
//|  EXECUTE TRADE                                                   |
//+------------------------------------------------------------------+
void ExecuteTrade(SMCSetup &setup)
{
   double lots = CalculateLotSize(setup.entry, setup.sl);
   if(lots <= 0) { Print("AstralAlgo: Lot size calc failed — skipping"); return; }

   bool ok = false;
   if(setup.isBull) {
      ok = Trade.Buy(lots, _Symbol, setup.entry, setup.sl, setup.tp1,
                     EA_Name + " | Conf:" + DoubleToString(setup.confidence,0) + "%");
   } else {
      ok = Trade.Sell(lots, _Symbol, setup.entry, setup.sl, setup.tp1,
                      EA_Name + " | Conf:" + DoubleToString(setup.confidence,0) + "%");
   }

   if(ok) {
      g_SigCount++;
      g_TradedToday = true;
      string dir = setup.isBull ? "BUY" : "SELL";
      ulong  newTicket = Trade.ResultOrder(); // ticket of the position just opened

      Print("✦ AstralAlgo TRADE FIRED | ", dir, " | ", _Symbol,
            " | Entry:", DoubleToString(setup.entry, _Digits),
            " | SL:", DoubleToString(setup.sl, _Digits),
            " | TP1:", DoubleToString(setup.tp1, _Digits),
            " | Lots:", DoubleToString(lots, 2),
            " | RR:", DoubleToString(setup.rr, 2),
            " | Conf:", DoubleToString(setup.confidence, 0), "%",
            " | ", setup.reason);

      // Journal
      WriteJournal(dir, setup, lots);

      // ── Backend Bridge ──────────────────────────────────────────
      // Posts the signal to main.py so it's saved to Supabase and
      // pushed live to the website dashboard. The backend itself
      // sends the Telegram alert when BridgeSendsTelegram is true,
      // so the EA skips its own Telegram call below to avoid a
      // duplicate message landing in the same group.
      string bridgeSignalId = "";
      if(UseBackendBridge) {
         bridgeSignalId = BridgePostSignal(setup, lots, newTicket);
      }

      // Telegram — sent directly by the EA only when either the bridge
      // is disabled, or the bridge is enabled but explicitly configured
      // NOT to send Telegram itself (BridgeSendsTelegram = false).
      bool eaShouldSendTelegram = EnableTelegram && AlertOnEntry
                                  && !(UseBackendBridge && BridgeSendsTelegram);

      if(eaShouldSendTelegram) {
         string msg = (setup.isBull ? "⚡ *BUY SIGNAL — " : "⚡ *SELL SIGNAL — ") + _Symbol + "*\n\n"
            + "📌 *Entry:*    `" + DoubleToString(setup.entry, _Digits) + "`\n"
            + "🎯 *TP 1:*    `" + DoubleToString(setup.tp1,  _Digits) + "`\n"
            + "🎯 *TP 2:*    `" + DoubleToString(setup.tp2,  _Digits) + "`\n"
            + "🎯 *TP 3:*    `" + DoubleToString(setup.tp3,  _Digits) + "`\n"
            + "🔴 *SL:*      `" + DoubleToString(setup.sl,   _Digits) + "`\n\n"
            + "📊 *RR:*      1 : " + DoubleToString(setup.rr, 1) + "\n"
            + "🎲 *Confidence:* " + DoubleToString(setup.confidence, 0) + "%\n"
            + "📦 *Lots:*    " + DoubleToString(lots, 2) + "\n"
            + "⏱ *Session:* " + GetCurrentSession() + "\n\n"
            + "✅ *Confluences:* " + setup.reason + "\n\n"
            + "🛡️ _PropFirm Mode: " + (EnablePropFirm ? "Active" : "Off") + "_\n"
            + "_— Astral Algo © 2026_";
         SendTelegram(msg);
      }
   } else {
      Print("AstralAlgo: Trade failed | Error: ", Trade.ResultRetcode(),
            " | ", Trade.ResultComment());
   }
}

//+------------------------------------------------------------------+
//|  MANAGE OPEN POSITIONS — Trailing, BE, Partial Close             |
//+------------------------------------------------------------------+
void ManageOpenPositions()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--) {
      if(!PosInfo.SelectByIndex(i)) continue;
      if(PosInfo.Magic() != Magic)   continue;
      if(PosInfo.Symbol() != _Symbol) continue;

      double openPrice   = PosInfo.PriceOpen();
      double currentSL   = PosInfo.StopLoss();
      double currentTP   = PosInfo.TakeProfit();
      double volume      = PosInfo.Volume();
      ulong  ticket      = PosInfo.Ticket();
      bool   isBull      = (PosInfo.PositionType() == POSITION_TYPE_BUY);
      double bid         = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double ask         = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double currentPrice= isBull ? bid : ask;
      double slDist      = MathAbs(openPrice - currentSL);

      if(slDist <= 0) continue;

      // ── Break Even ───────────────────────────────────────────────
      if(UseBreakEven) {
         double rMultiple = (isBull ? currentPrice - openPrice : openPrice - currentPrice) / slDist;
         if(rMultiple >= BreakEvenR) {
            double newSL = isBull
               ? openPrice + 5 * _Point  // 5 points above entry (locks profit)
               : openPrice - 5 * _Point;
            if((isBull && currentSL < newSL) || (!isBull && currentSL > newSL)) {
               Trade.PositionModify(ticket, newSL, currentTP);
            }
         }
      }

      // ── Partial Close at TP1 ─────────────────────────────────────
      if(PartialCloseR > 0) {
         double rMultiple = (isBull ? currentPrice - openPrice : openPrice - currentPrice) / slDist;
         if(rMultiple >= PartialCloseR && volume > SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN) * 2) {
            double closeVol = NormalizeDouble(volume * PartialClosePct / 100.0, 2);
            closeVol = MathMax(closeVol, SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN));
            if(closeVol < volume) {
               Trade.PositionClosePartial(ticket, closeVol);
               if(AlertOnTP && EnableTelegram) {
                  SendTelegram("✅ *PARTIAL CLOSE — " + _Symbol + "*\n"
                     + "Closed " + DoubleToString(PartialClosePct, 0) + "% at TP1\n"
                     + "Remaining: " + DoubleToString(volume - closeVol, 2) + " lots running");
               }
            }
         }
      }

      // ── Trailing Stop ────────────────────────────────────────────
      if(UseTrailingStop) {
         double rMultiple = (isBull ? currentPrice - openPrice : openPrice - currentPrice) / slDist;
         if(rMultiple >= TrailStartR) {
            double trailDist = TrailStepPoints * _Point;
            double newSL = isBull
               ? currentPrice - trailDist
               : currentPrice + trailDist;
            bool shouldMove = isBull
               ? (newSL > currentSL + _Point)
               : (newSL < currentSL - _Point);
            if(shouldMove) Trade.PositionModify(ticket, newSL, currentTP);
         }
      }
   }
}

//+------------------------------------------------------------------+
//|  LOT SIZE CALCULATOR                                             |
//|  Risk-based, respects broker min/max and step                    |
//+------------------------------------------------------------------+
double CalculateLotSize(double entry, double sl)
{
   double balance  = AccountInfoDouble(ACCOUNT_BALANCE);
   double riskAmt  = balance * RiskPercent / 100.0;
   double slPoints = MathAbs(entry - sl) / _Point;

   if(slPoints <= 0) return 0;

   double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickValue <= 0 || tickSize <= 0) return 0;

   double valuePerPoint = tickValue / tickSize * _Point;
   if(valuePerPoint <= 0) return 0;

   double rawLots = riskAmt / (slPoints * valuePerPoint);

   double lotStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   double lotMin  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double lotMax  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);

   double lots = MathFloor(rawLots / lotStep) * lotStep;
   lots = MathMax(lots, lotMin);
   lots = MathMin(lots, lotMax);

   return lots;
}

//+------------------------------------------------------------------+
//|  PROPFIRM GUARD                                                  |
//+------------------------------------------------------------------+
bool PassPropFirmGuard()
{
   double balance   = AccountInfoDouble(ACCOUNT_BALANCE);
   double equity    = AccountInfoDouble(ACCOUNT_EQUITY);
   double startBal  = g_StartBalance;

   // Total drawdown check
   double totalDD = (startBal - equity) / startBal * 100.0;
   if(totalDD >= MaxTotalDrawPct) {
      if(EnableTelegram) SendTelegram("🚨 *PROPFIRM ALERT — MAX DRAWDOWN HIT*\n"
         + "Total DD: " + DoubleToString(totalDD, 2) + "%\n"
         + "Trading halted. Review your account immediately.");
      CloseAllPositions("Max total drawdown reached");
      return false;
   }

   // Daily loss check
   double dailyDD = (g_DailyStartBalance - equity) / g_DailyStartBalance * 100.0;
   if(dailyDD >= MaxDailyLossPct) {
      if(EnableTelegram) SendTelegram("⚠️ *DAILY LOSS LIMIT HIT — " + _Symbol + "*\n"
         + "Daily DD: " + DoubleToString(dailyDD, 2) + "%\n"
         + "No new trades today. Existing positions managed.");
      return false;
   }

   // Daily profit target (stop trading after target hit)
   double dailyGain = (equity - g_DailyStartBalance) / g_DailyStartBalance * 100.0;
   if(dailyGain >= DailyProfitTarget) {
      Print("AstralAlgo: Daily profit target reached (", dailyGain, "%). No new trades.");
      return false;
   }

   return true;
}

//+------------------------------------------------------------------+
//|  SESSION / KILL ZONE CHECK                                       |
//+------------------------------------------------------------------+
bool InKillZone()
{
   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   int hr = dt.hour;

   if(LondonKZ  && hr >= LondonStartHr  && hr < LondonEndHr)  return true;
   if(NewYorkKZ && hr >= NYStartHr      && hr < NYEndHr)       return true;
   if(LondonCloseKZ && hr >= LCStartHr && hr < LCEndHr)       return true;
   if(AsianKZ   && hr >= AsianStartHr   && hr < AsianEndHr)   return true;
   return false;
}

string GetCurrentSession()
{
   MqlDateTime dt; TimeToStruct(TimeCurrent(), dt); int hr = dt.hour;
   if(hr >= LondonStartHr && hr < LondonEndHr) return "London Kill Zone";
   if(hr >= NYStartHr     && hr < NYEndHr)     return "New York Kill Zone";
   if(hr >= LCStartHr     && hr < LCEndHr)     return "London Close";
   if(hr >= AsianStartHr  && hr < AsianEndHr)  return "Asian Kill Zone";
   return "Off-Session";
}

