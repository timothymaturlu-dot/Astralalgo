void WriteJournal(string dir, SMCSetup &setup, double lots)
{
   if(g_JournalHandle == INVALID_HANDLE) return;
   FileWrite(g_JournalHandle,
      TimeToString(TimeCurrent()),
      _Symbol, dir,
      DoubleToString(setup.entry, _Digits),
      DoubleToString(setup.sl,    _Digits),
      DoubleToString(setup.tp1,   _Digits),
      DoubleToString(setup.tp2,   _Digits),
      DoubleToString(setup.tp3,   _Digits),
      DoubleToString(lots, 2),
      DoubleToString(setup.rr, 2),
      DoubleToString(setup.confidence, 0),
      "OPEN", "", "",
      setup.reason);
   FileFlush(g_JournalHandle);
}

